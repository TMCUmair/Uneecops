%dw 2.0
output application/java
---
payload map ((item, index) ->{
	Company_Number__c: if(item.HHHCMPN?) trim(item.HHHCMPN)  default  "" else "KeyToBeRemoved",
	Division_Number__c: if(item.HHHDIVN?) trim(item.HHHDIVN)  default  "" else "KeyToBeRemoved",
	Department_Number__c: if(item.HHHDPTN?) trim(item.HHHDPTN)  default  "" else "KeyToBeRemoved",
	Account__c: if(item.HHHCUSN?) trim(item.HHHCUSN)  default  "" else "KeyToBeRemoved",
	Order_Number__c: trim(item.HHHORNR),
	Order_Type__c: if(item.HHHORTY?) trim(item.HHHORTY)  default  "" else "KeyToBeRemoved",
	Memo_Billing_Code__c: if(item.HHHMEMO?) trim(item.HHHMEMO)  default  "" else "KeyToBeRemoved",
	Memo_Billing_Code_2__c: if(item.HHHMEM2?) trim(item.HHHMEM2)  default  "" else "KeyToBeRemoved",
	Warehouse_Number__c: if(item.HHHWHSN?) trim(item.HHHWHSN)  default  "" else "KeyToBeRemoved",
	Remote_Set_Number__c: if(item.HHHSETN?) trim(item.HHHSETN)  default  "" else "KeyToBeRemoved",
//						: item.HHHSETN,
//						: item.HHHCNMB,
//						: item.HHHCA1B,
//						: item.HHHCA2B,
//						: item.HHHCTYB,
//						: item.HHHSTEB,
//						: item.HHHZPCB,
	Active_Record_Code__c: if(item.HHHARCD?) trim(item.HHHARCD)  default  "" else "KeyToBeRemoved",
	Salesrep__c: if(item.HHHSLNB?) trim(item.HHHSLNB)  default  "" else "KeyToBeRemoved",
	Ship_Date__c: if(item.HHHDTES?) (if(!isEmpty(item.HHHDTES)) ((item.HHHDTES[0 to 3]++'-' ++ item.HHHDTES[4 to 5]++'-' ++ item.HHHDTES[6 to 7]) as Date {format: "yyyy-MM-dd"}  default null) else null) else "KeyToBeRemoved",
	Order_Date__c: if(item.HHHDTET?) (if(!isEmpty(item.HHHDTET)) ((item.HHHDTET[0 to 3]++'-' ++ item.HHHDTET[4 to 5]++'-' ++ item.HHHDTET[6 to 7]) as Date {format: "yyyy-MM-dd"}  default null) else null) else "KeyToBeRemoved",
	Special_Instructions__c: if(item.HHHINSI?) trim(item.HHHINSI)  default  "" else "KeyToBeRemoved",
	Special_Instructions_2__c: if(item.HHHINS2?) trim(item.HHHINS2)  default  "" else "KeyToBeRemoved",
	Invoice_Reference_Number__c: if(item.HHHINVR?) trim(item.HHHINVR)  default  "" else "KeyToBeRemoved",
	Terms_Code__c: if(item.HHHTRMC?) trim(item.HHHTRMC)  default  "" else "KeyToBeRemoved",
	User_id__c: if(item.HHHUSER?) trim(item.HHHUSER)  default  "" else "KeyToBeRemoved",
	User_id_1__c: if(item.HHHUSR1?) trim(item.HHHUSR1)  default  "" else "KeyToBeRemoved",
	User_id_2__c: if(item.HHHUSR2?) trim(item.HHHUSR2)  default  "" else "KeyToBeRemoved",
	Time_of_order__c: if(item.HHHTIMO?) trim(item.HHHTIMO)  default  "" else "KeyToBeRemoved",
	Time__c: if(item.HHHTIME?) trim(item.HHHTIME)  default  "" else "KeyToBeRemoved",
	Fiscal_year__c: if(item.HHHFSYR?) trim(item.HHHFSYR)  default  "" else "KeyToBeRemoved",
	Fiscal_Period__c: if(item.HHHFSPD?) trim(item.HHHFSPD)  default  "" else "KeyToBeRemoved",
	Current_week_of_year__c: if(item.HHHWEKC?) trim(item.HHHWEKC)  default  "" else "KeyToBeRemoved",
	Calendar_Year__c: if(item.HHHCLYR?) trim(item.HHHCLYR)  default  "" else "KeyToBeRemoved",
	Calendar_week__c: if(item.HHHCLWK?) trim(item.HHHCLWK)  default  "" else "KeyToBeRemoved",
	Invoice_number__c: if(item.HHHINVN?) trim(item.HHHINVN)  default  "" else "KeyToBeRemoved",
	Date_of_last_order__c: if(item.HHHDTEI?) (if(!isEmpty(item.HHHDTEI)) ((item.HHHDTEI[0 to 3]++'-' ++ item.HHHDTEI[4 to 5]++'-' ++ item.HHHDTEI[6 to 7]) as Date {format: "yyyy-MM-dd"}  default null) else null) else "KeyToBeRemoved",
	Invoice_Amount__c: if(item.HHHINAM?) item.HHHINAM  default  null else "KeyToBeRemoved",
	Quantity_Ordered__c: if(item.HHHQYOA?) item.HHHQYOA  default  null else "KeyToBeRemoved",
	Quantity_Shipped__c: if(item.HHHQYSA?) item.HHHQYSA  default  null else "KeyToBeRemoved",
	Ext_case_cube__c: if(item.HHHEXCB?) item.HHHEXCB  default  null else "KeyToBeRemoved",
	Ext_ship_weight__c: if(item.HHHEXSH?) item.HHHEXSH  default  null else "KeyToBeRemoved",
	Ext_sales_gross__c: if(item.HHHEXSG?) item.HHHEXSG  default  null else "KeyToBeRemoved",
	Ext_sales_net__c: if(item.HHHEXSN?) item.HHHEXSN  default  null else "KeyToBeRemoved",
	Ext_salesrep_cost_gross__c: if(item.HHHEXCG?) item.HHHEXCG  default  null else "KeyToBeRemoved",
	Ext_salesrep_cost_net__c: if(item.HHHEXCR?) item.HHHEXCR  default  null else "KeyToBeRemoved",
	Ext_actual_cost__c: if(item.HHHEXAC?) item.HHHEXAC  default  null else "KeyToBeRemoved",
	Ext_bid_sales_amount__c: if(item.HHHEXBS?) item.HHHEXBS  default  null else "KeyToBeRemoved",
	O_E_ext_mkt_cost__c: if(item.HHHEXMC?) item.HHHEXMC  default  null else "KeyToBeRemoved",
	O_E_ext_slsrep_cost__c: if(item.HHHEXRC?) item.HHHEXRC  default  null else "KeyToBeRemoved",
	Chain_store_code__c: if(item.HHHCSCD?) trim(item.HHHCSCD)  default  "" else "KeyToBeRemoved"
} filterObject ((value, key, index) -> value != "KeyToBeRemoved")
)